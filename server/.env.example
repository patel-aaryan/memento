# Neon Database Configuration
DATABASE_URL=<your_database_url>

# Server Configuration
DEBUG=True

# Authentication Configuration
SECRET_KEY=your-secret-key-change-this-to-something-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
PASSWORD_RESET_CODE_EXPIRE_MINUTES=15

# Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=your-email@your-domain.com

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# Google API Configuration
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI (optional) — AI album suggestions from "My Photos"
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ALBUM_SUGGESTION_OPENAI_COOLDOWN_SECONDS=90